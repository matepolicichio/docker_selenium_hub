# Selenium Hub
SELENIUM_SESSION_ACCESS_KEY=     # Bearer token para crear sesiones WebDriver
SE_ROUTER_USERNAME=              # Usuario para Basic Auth (UI + API REST)
SE_ROUTER_PASSWORD=              # Contraseña para Basic Auth (UI + API REST)

# MongoDB — inactivo, para implementación futura
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
ME_CONFIG_MONGODB_ADMINUSERNAME=
ME_CONFIG_MONGODB_ADMINPASSWORD=
ME_CONFIG_MONGODB_URL=           # mongodb://user:password@mongo:27017/
ME_CONFIG_BASICAUTH_USERNAME=    # Usuario para la UI de mongo-express
ME_CONFIG_BASICAUTH_PASSWORD=    # Contraseña para la UI de mongo-express
