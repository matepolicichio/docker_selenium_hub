# Proxy SOCKS5 - accesible desde cualquier IP de la red Docker (no del host)
# IsolateDestAddr: streams a destinos distintos no comparten circuito.
# IsolateClientAddr e IsolateSOCKSAuth eliminados: todos los workers comparten
# IP de origen y no usan auth → flags redundantes que no aportan aislamiento.
SocksPort 0.0.0.0:9050 IsolateDestAddr   # hermes-notifier / bot-mx    (hasta 5 workers)
SocksPort 0.0.0.0:9052 IsolateDestAddr   # atenea-notifier / bot-latam (hasta 4 workers)
SocksPort 0.0.0.0:9053 IsolateDestAddr   # apollo-notifier / bot-test  (hasta 3 workers)
# 9051 reservado para ControlPort — no usar como SocksPort

# Control port — accesible desde la red Docker (para SIGNAL NEWNYM desde el bot)
# Tor rechaza CookieAuthentication 0 en 0.0.0.0 por diseño. Se usa HashedControlPassword.
# Para regenerar el hash: docker exec tor tor --hash-password TU_PASSWORD
ControlPort 0.0.0.0:9051
HashedControlPassword 16:F480E2358B0791DC606AB68BDC736DB3C1226B77A783801657D8C9AB24

# Logging: "notice" para producción (debug genera miles de líneas por sesión)
Log notice stdout

# Circuitos
MaxCircuitDirtiness 60
CircuitBuildTimeout 90
NewCircuitPeriod 60
# Más guard nodes = mayor variedad de primer hop y menos cuello de botella
# cuando múltiples workers construyen circuitos en paralelo.
NumEntryGuards 9   # 3 containers × 3 guards mínimo

# Nodos de salida — pool ampliado con países estables, jurisdicciones limpias,
# latencia razonable a ais.usvisa-info.com y sin riesgo de geo-block.
# {us,ca,au,gb,nz} → Five Eyes (máxima compatibilidad con portal US gov)
# {de,nl,fr,se,ch} → Europa occidental (grandes pools Tor, jurisdicciones pro-privacidad)
ExitNodes {us},{ca},{au},{gb},{nz},{de},{nl},{fr},{se},{ch}
StrictNodes 0

# Restricción de acceso al proxy SOCKS5
# Solo se aceptan conexiones desde rangos de red Docker internos.
# Impide que el proxy sea usado por procesos externos al stack.
SOCKSPolicy accept 172.16.0.0/12
SOCKSPolicy accept 10.0.0.0/8
SOCKSPolicy reject *
